{
  "name": "perceptor",
  "displayName": "Perceptor",
  "description": "Perceptor X-rays your repository: an interactive dependency & behavior map plus per-method analysis — Big-O complexity and N+1 / SQL-ORM query risk — with optional Claude-powered edits that use your own local Claude CLI and tokens.",
  "version": "0.6.0",
  "publisher": "berkcansavur",
  "author": "Berkcan Şavur",
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "visualization",
    "dependency graph",
    "architecture",
    "code analysis",
    "complexity",
    "big o",
    "n+1",
    "claude",
    "refactoring"
  ],
  "galleryBanner": {
    "color": "#0b0e14",
    "theme": "dark"
  },
  "pricing": "Free",
  "repository": {
    "type": "git",
    "url": "https://github.com/berkcansavur/perceptor.git"
  },
  "bugs": {
    "url": "https://github.com/berkcansavur/perceptor/issues"
  },
  "homepage": "https://github.com/berkcansavur/perceptor#readme",
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "perceptor.open",
        "title": "Open",
        "category": "Perceptor"
      },
      {
        "command": "perceptor.inlineEdit",
        "title": "Inline Edit",
        "category": "Perceptor"
      },
      {
        "command": "perceptor.submitInlineEdit",
        "title": "Submit",
        "icon": "$(send)"
      },
      {
        "command": "perceptor.closeInlineEdit",
        "title": "Close",
        "icon": "$(close)"
      },
      {
        "command": "perceptor.attachFileInlineEdit",
        "title": "Attach File",
        "icon": "$(file-add)"
      },
      {
        "command": "perceptor.stopInlineEdit",
        "title": "Stop",
        "icon": "$(debug-stop)"
      },
      {
        "command": "perceptor.viewInChat",
        "title": "View in Chat",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "perceptor.removeAttachedFileInlineEdit",
        "title": "Remove Attached File",
        "icon": "$(trash)"
      },
      {
        "command": "perceptor.simulate",
        "title": "Debug with Perceptor",
        "category": "Perceptor"
      },
      {
        "command": "perceptor.closeSimulation",
        "title": "Close",
        "icon": "$(close)"
      },
      {
        "command": "perceptor.stopSimulation",
        "title": "Stop",
        "icon": "$(debug-stop)"
      }
    ],
    "menus": {
      "comments/commentThread/context": [
        {
          "command": "perceptor.submitInlineEdit",
          "group": "inline",
          "when": "commentController == perceptor-inline && !perceptor.inlineProcessing"
        },
        {
          "command": "perceptor.attachFileInlineEdit",
          "group": "inline",
          "when": "commentController == perceptor-inline && !perceptor.inlineProcessing"
        },
        {
          "command": "perceptor.removeAttachedFileInlineEdit",
          "group": "inline",
          "when": "commentController == perceptor-inline && !perceptor.inlineProcessing && perceptor.inlineHasAttachments"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "perceptor.viewInChat",
          "group": "inline",
          "when": "commentController == perceptor-inline && perceptor.inlineHasTask"
        },
        {
          "command": "perceptor.stopInlineEdit",
          "group": "inline",
          "when": "commentController == perceptor-inline && perceptor.inlineProcessing"
        },
        {
          "command": "perceptor.closeInlineEdit",
          "group": "inline",
          "when": "commentController == perceptor-inline"
        },
        {
          "command": "perceptor.stopSimulation",
          "group": "inline",
          "when": "commentController == perceptor-debugger && perceptor.simulationProcessing"
        },
        {
          "command": "perceptor.closeSimulation",
          "group": "inline",
          "when": "commentController == perceptor-debugger && perceptor.simulationActive"
        }
      ]
    },
    "keybindings": [
      {
        "command": "perceptor.inlineEdit",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Perceptor",
      "properties": {
        "perceptor.claudePath": {
          "type": "string",
          "default": "",
          "description": "Path to the Claude CLI used to process tasks. Leave empty to auto-detect via your login shell (recommended). Set an absolute path to override."
        },
        "perceptor.autoProcessOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically enable Auto-process when the panel opens. Off by default to avoid spending Claude tokens unexpectedly."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "node esbuild.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.21.0",
    "perceptor-core": "*",
    "vitest": "^3.2.4"
  }
}
