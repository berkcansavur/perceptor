{
  "name": "repo-visualiser",
  "version": "0.1.0",
  "description": "Interactive dependency/behavior map for a code repository (analyzer + server + CLI).",
  "license": "MIT",
  "bin": {
    "visualise": "dist/cli.js"
  },
  "main": "dist/core/index.js",
  "types": "dist/core/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node build-web.js",
    "check-types": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "analyze": "node dist/cli.js --analyze-only",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "tree-sitter-wasms": "^0.1.11",
    "web-tree-sitter": "^0.22.6"
  },
  "devDependencies": {
    "esbuild": "^0.21.0"
  }
}
